{
  "compilerOptions": {
      "module": "commonjs",
      "outDir": "build",
      "incremental": true,
      "pretty": true,
      "noFallthroughCasesInSwitch": true,
      "noImplicitReturns": true,
      "noUnusedParameters": true,
      "noUnusedLocals": true,
      "noImplicitAny": true,
      "declaration": true,
      "strictNullChecks": true,
      "strictFunctionTypes": true,
      "alwaysStrict": true,
      "target": "es2017",
      "sourceMap": true,
      "types": [
          "node",
          "mocha",
          "chai"
      ]
      },
  "filesGlob": [
      "./**/*.ts"
      ],
  "exclude": [
      "node_modules",
      "docs",
      "build"
  ]
}